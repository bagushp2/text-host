# Salin ke .env.local untuk pengembangan lokal (jangan commit .env.local).
# Nilai ini otomatis terisi kalau kamu pakai integrasi Upstash di dashboard Vercel.

# --- Integrasi Upstash langsung (upstash.com) ---
UPSTASH_REDIS_REST_URL="https://xxxxx.upstash.io"
UPSTASH_REDIS_REST_TOKEN="xxxxxxxxxxxxxxxxxxxx"

# --- Alternatif: Vercel Marketplace / KV (nama variabel lama) ---
# KV_REST_API_URL="https://xxxxx.upstash.io"
# KV_REST_API_TOKEN="xxxxxxxxxxxxxxxxxxxx"
